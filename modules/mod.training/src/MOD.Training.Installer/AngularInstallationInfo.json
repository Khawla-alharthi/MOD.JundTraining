{
  "packages":[
    {
      "appRoutingModuleConfiguration":{
        "imports":[
          {
            "names":[
              "TRAINING_ROUTES"
            ],
            "namespace": "@m-oD/training"
          } 
        ],
        "routes":[
          "{ path: 'training', children: TRAINING_ROUTES, canActivate: [authGuard] }"
        ]
      },
      "appModuleConfiguration":{
        "imports":[
          {
            "names":[
              "provideTraining"
            ],
            "namespace": "@m-oD/training/config"
          }
        ],
        "providerNames":[
          "provideTraining()"
        ]
      },
      "tsJsonPathRecordConfigurations":[
        {
          "name": "@m-oD/training",
          "paths": [
            "angular/projects/training/src/public-api.ts"
          ]
        },
        {
          "name": "@m-oD/training/config",
          "paths": [
            "angular/projects/training/config/src/public-api.ts"
          ]
        }
      ]
    }
  ]
}